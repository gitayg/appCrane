# DeployHub Configuration
PORT=5001
HOST=0.0.0.0

# Encryption key for env vars (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ENCRYPTION_KEY=

# Email notifications (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=deployhub@example.com

# AppCrane's own domain (for Caddyfile generation)
CRANE_DOMAIN=crane.example.com

# Base domain for managed apps
BASE_DOMAIN=example.com

# Caddy admin API (Linux only)
CADDY_ADMIN_URL=http://localhost:2019

# Data directory
DATA_DIR=./data
